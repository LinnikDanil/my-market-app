POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=market

MARKET_SERVER_PORT=8080
PAYMENTS_SERVER_PORT=8081

DATASOURCE_SCHEMA_NAME=public
SPRING_R2DBC_URL=r2dbc:postgresql://db:5432/market
SPRING_R2DBC_USERNAME=postgres
SPRING_R2DBC_PASSWORD=postgres

SPRING_LIQUIBASE_URL=jdbc:postgresql://db:5432/market
SPRING_LIQUIBASE_USER=postgres
SPRING_LIQUIBASE_PASSWORD=postgres

LOGGING_PRACTICUM_LEVEL=DEBUG

SPRING_WEBFLUX_MULTIPART_MAX_DISK_USAGE_PER_PART=10MB
SPRING_WEBFLUX_MULTIPART_MAX_IN_MEMORY_SIZE=1MB
SPRING_WEBFLUX_MULTIPART_MAX_PARTS=256
SPRING_CODEC_MAX_IN_MEMORY_SIZE=2MB

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL=PT1M

IMAGE_PATH=/market-app/images
IMAGE_PUBLIC_URI_PREFIX=/images/
IMAGE_RESOURCE_HANDLER_PATTERN=/images/**

PAYMENTS_BASE_URL=http://payments-app:8081
PAYMENTS_WEBCLIENT_POOL_NAME=payments-pool
PAYMENTS_WEBCLIENT_POOL_MAX_CONNECTIONS=50
PAYMENTS_WEBCLIENT_POOL_PENDING_ACQUIRE_TIMEOUT=PT2S
PAYMENTS_WEBCLIENT_POOL_MAX_IDLE_TIME=PT30S
PAYMENTS_WEBCLIENT_CONNECT_TIMEOUT_MILLIS=2000
PAYMENTS_WEBCLIENT_RESPONSE_TIMEOUT=PT3S
PAYMENTS_WEBCLIENT_READ_TIMEOUT=PT3S
PAYMENTS_WEBCLIENT_WRITE_TIMEOUT=PT3S
